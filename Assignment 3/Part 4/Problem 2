#include <iostream>
using namespace std;

int main()
{
    int R, C;
    cout << "Enter Rows and Columns: ";
    cin >> R >> C;

    int arr[R][C];

    for(int i = 0; i < R; i++)
    {
        for(int j = 0; j < C; j++)
        {
            cout << "Enter value for (" << i << ", " << j << "): ";
            cin >> arr[i][j];
        }
    }

    int result = arr[0][0];

    for(int i = 0; i < R; i++)
    {
        for(int j = 0; j < C; j++)
        {
            if(i == 0 && j == 0) continue; // skip the starting element itself
            result -= arr[i][j];
        }
    }

    cout << "Final Result: " << result << endl;

    return 0;
}
