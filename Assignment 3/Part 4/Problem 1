#include <iostream>
using namespace std;

int main()
{
    int R, C;
    cout << "Enter Rows and Columns: ";
    cin >> R >> C;

    int arr[R][C];
    int sum = 0;

    for(int i = 0; i < R; i++)
    {
        for(int j = 0; j < C; j++)
        {
            cout << "Enter value for (" << i << ", " << j << "): ";
            cin >> arr[i][j];
            sum += arr[i][j];
        }
    }

    cout << "Sum of all elements: " << sum << endl;

    return 0;
}
